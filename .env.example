# Claves API necesarias
TAVILY_API_KEY="tu_clave_api_de_tavily"

# Configuración de Azure OpenAI (Azure AI Foundry)
AZURE_OPENAI_API_KEY="TU_CLAVE_DE_AZURE_OPENAI"
AZURE_OPENAI_ENDPOINT="https://<TU_RECURSO>.openai.azure.com/"
OPENAI_API_VERSION="2024-02-15-preview"
MODEL_NAME="gpt-4o-mini" # Cambia esto por el nombre de tu "Deployment" en Azure

# Configuración de LangSmith para Tracing
LANGCHAIN_TRACING_V2="true"
LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"
LANGCHAIN_API_KEY="tu_clave_api_de_langsmith"
LANGCHAIN_PROJECT="langgraph-research-agent"
